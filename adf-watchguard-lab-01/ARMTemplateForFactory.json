{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "adf-watchguard-lab-01"
		},
		"GITHUB_using_httplink_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'GITHUB_using_httplink'"
		},
		"ls_snowflake_poc_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'ls_snowflake_poc'"
		},
		"GITHUB_using_httplink_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://raw.githubusercontent.com/Lavanya-k-devops/my-adf-snowflake-lab/refs/heads/main/sample_data.csv"
		},
		"GITHUB_using_httplink_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "Lavanya-k-devops"
		},
		"ls_snowflake_poc_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "POC_DB"
		},
		"ls_snowflake_poc_properties_typeProperties_role": {
			"type": "string",
			"defaultValue": "SYSADMIN"
		},
		"ls_snowflake_poc_properties_typeProperties_host": {
			"type": "string",
			"defaultValue": "LAZJGVP-KNB26294.snowflakecomputing.com"
		},
		"storageaccount_sasUri": {
			"type": "secureString",
			"metadata": "Secure string for 'sasUri' of 'storageaccount'"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "[concat(parameters('factoryName'), '/pl_github_to_snowflake')]",
			"type": "Microsoft.DataFactory/factories/pipelines",
			"apiVersion": "2018-06-01",
			"properties": {
				"activities": [
					{
						"name": "my_first_activity",
						"description": "testing with new git branch",
						"type": "Copy",
						"dependsOn": [],
						"policy": {
							"timeout": "0.12:00:00",
							"retry": 0,
							"retryIntervalInSeconds": 30,
							"secureOutput": false,
							"secureInput": false
						},
						"userProperties": [],
						"typeProperties": {
							"source": {
								"type": "DelimitedTextSource",
								"storeSettings": {
									"type": "HttpReadSettings",
									"requestMethod": "GET"
								},
								"formatSettings": {
									"type": "DelimitedTextReadSettings"
								}
							},
							"sink": {
								"type": "SnowflakeV2Sink",
								"importSettings": {
									"type": "SnowflakeImportCopyCommand"
								}
							},
							"enableStaging": true,
							"stagingSettings": {
								"linkedServiceName": {
									"referenceName": "storageaccount",
									"type": "LinkedServiceReference"
								},
								"path": "staging"
							},
							"translator": {
								"type": "TabularTranslator",
								"mappings": [
									{
										"source": {
											"name": "EMP_ID",
											"type": "String"
										},
										"sink": {
											"name": "EMP_ID",
											"type": "Decimal"
										}
									},
									{
										"source": {
											"name": "EMP_NAME",
											"type": "String"
										},
										"sink": {
											"name": "EMP_NAME",
											"type": "String"
										}
									},
									{
										"source": {
											"name": "CITY",
											"type": "String"
										},
										"sink": {
											"name": "CITY",
											"type": "String"
										}
									}
								]
							}
						},
						"inputs": [
							{
								"referenceName": "github_sample",
								"type": "DatasetReference",
								"parameters": {}
							}
						],
						"outputs": [
							{
								"referenceName": "SnowflakeTable1",
								"type": "DatasetReference",
								"parameters": {}
							}
						]
					}
				],
				"policy": {
					"elapsedTimeMetric": {}
				},
				"annotations": []
			},
			"dependsOn": [
				"[concat(variables('factoryId'), '/datasets/github_sample')]",
				"[concat(variables('factoryId'), '/datasets/SnowflakeTable1')]",
				"[concat(variables('factoryId'), '/linkedServices/storageaccount')]"
			]
		},
		{
			"name": "[concat(parameters('factoryName'), '/SnowflakeTable1')]",
			"type": "Microsoft.DataFactory/factories/datasets",
			"apiVersion": "2018-06-01",
			"properties": {
				"linkedServiceName": {
					"referenceName": "ls_snowflake_poc",
					"type": "LinkedServiceReference"
				},
				"annotations": [],
				"type": "SnowflakeV2Table",
				"schema": [],
				"typeProperties": {
					"schema": "POC_SCHEMA",
					"table": "GITHUB_DATA"
				}
			},
			"dependsOn": [
				"[concat(variables('factoryId'), '/linkedServices/ls_snowflake_poc')]"
			]
		},
		{
			"name": "[concat(parameters('factoryName'), '/github_sample')]",
			"type": "Microsoft.DataFactory/factories/datasets",
			"apiVersion": "2018-06-01",
			"properties": {
				"linkedServiceName": {
					"referenceName": "GITHUB_using_httplink",
					"type": "LinkedServiceReference"
				},
				"annotations": [],
				"type": "DelimitedText",
				"typeProperties": {
					"location": {
						"type": "HttpServerLocation"
					},
					"columnDelimiter": ",",
					"escapeChar": "\\",
					"firstRowAsHeader": true,
					"quoteChar": "\""
				},
				"schema": []
			},
			"dependsOn": [
				"[concat(variables('factoryId'), '/linkedServices/GITHUB_using_httplink')]"
			]
		},
		{
			"name": "[concat(parameters('factoryName'), '/GITHUB_using_httplink')]",
			"type": "Microsoft.DataFactory/factories/linkedServices",
			"apiVersion": "2018-06-01",
			"properties": {
				"annotations": [],
				"type": "HttpServer",
				"typeProperties": {
					"url": "[parameters('GITHUB_using_httplink_properties_typeProperties_url')]",
					"enableServerCertificateValidation": true,
					"authenticationType": "Basic",
					"userName": "[parameters('GITHUB_using_httplink_properties_typeProperties_userName')]",
					"password": {
						"type": "SecureString",
						"value": "[parameters('GITHUB_using_httplink_password')]"
					}
				}
			},
			"dependsOn": []
		},
		{
			"name": "[concat(parameters('factoryName'), '/ls_snowflake_poc')]",
			"type": "Microsoft.DataFactory/factories/linkedServices",
			"apiVersion": "2018-06-01",
			"properties": {
				"annotations": [],
				"type": "SnowflakeV2",
				"typeProperties": {
					"authenticationType": "Basic",
					"accountIdentifier": "LAZJGVP-KNB26294",
					"user": "LAVANYA",
					"database": "[parameters('ls_snowflake_poc_properties_typeProperties_database')]",
					"warehouse": "POC_WH",
					"role": "[parameters('ls_snowflake_poc_properties_typeProperties_role')]",
					"host": "[parameters('ls_snowflake_poc_properties_typeProperties_host')]",
					"password": {
						"type": "SecureString",
						"value": "[parameters('ls_snowflake_poc_password')]"
					},
					"useUtcTimestamps": false
				},
				"version": "1.1"
			},
			"dependsOn": []
		},
		{
			"name": "[concat(parameters('factoryName'), '/storageaccount')]",
			"type": "Microsoft.DataFactory/factories/linkedServices",
			"apiVersion": "2018-06-01",
			"properties": {
				"annotations": [],
				"type": "AzureBlobStorage",
				"typeProperties": {
					"sasUri": "[parameters('storageaccount_sasUri')]"
				}
			},
			"dependsOn": []
		}
	]
}